<% const header = {
    button: {
        id: 'closeBtn',
        dismissTarget: 'modal'
    },
    class: 'modal-header',
    title: {
        id: 'modalTitle',
        class: 'modal-title',
    }
}; 

const buttons = {
    backButton: {
        id: 'backBtn',
        class: 'btn btn-link',
        attrs: {
            'data-mdb-modal-init': '',
            'data-mdb-target': '#modal',
            'data-mdb-dismiss': 'modal'
        },
        content: 'Regresar'
    },
    cancelButton: {
        id: 'cancelBtn',
        class: 'btn btn-secondary',
        content: 'Cancelar'
    },
    confirmButton: {
        id: 'confirmBtn',
        class: 'btn btn-primary',
        content: 'Confirmar'
    }
}; %>

<div class="modal fade" id="modal" tabindex="-1" aria-labelledby="<%= header.title.id %>">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
        
        <%- include('./header', { header }) %>

        <div class="modal-body dark">
            <form id="form" class="row g-3" novalidate>
                <% if (form.selects) { %>
                    <%- include('./selectList', { inputs: form.selects }) %>
                <% } %>

                <%- include('./outlineInputList', { inputs: form.inputs }) %>

                <% if (form.checkboxes) { %>
                    <%- include('./checkboxList', { inputs: form.checkboxes }) %>
                <% } %>

                <% if (form.table) { %>
                    <div class="row g-2 mb-3 add-product-container">
                        <div class="col-4">
                            <%- include('./select', { input: form.table.select }) %>
                        </div>

                        <%- include('./outlineInputList', { inputs: form.table.inputs }) %>

                        <div class="col-2">
                            <%- include('./button', { button: form.table.button }) %>
                        </div>
                    </div>

                    <%- include('./productTable') %>
                <% } %>

                <div class="col-12">
                    <%- include('./button', { button: buttons.backButton }) %>

                    <div class="approve-container">
                        <%- include('./button', { button: buttons.cancelButton }) %>

                        <%- include('./button', { button: buttons.confirmButton }) %>
                    </div>
                    
                    <%- include('./submit') %>
                </div>
            </form>
        </div>

        </div>
    </div>
</div>