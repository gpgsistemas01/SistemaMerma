<% const form = {
    canApprove: true,
    selects: [
        {
            id: 'requesterInput',
            name: 'requesterId',
            col: '6'
        },
        {
            id: 'projectInput',
            name: 'projectId',
            col: '6'
        }
    ],
    inputs: [
        {
            id: 'observationsInput',
            name: 'observations',
            type: 'text',
            label: 'Observaciones',
        },
        {
            id: 'requestDateInput',
            name: 'requestDate',
            type: 'datetime-local',
            label: 'Fecha y hora de solicitud:',
        }
    ],
    table: {
        select: {
            id: 'productInput',
            name: 'productId',
            label: 'Producto'
        },
        inputs: [
            {
                id: 'quantityInput',
                name: 'quantity',
                type: 'number',
                label: 'Cantidad',
                col: '3'
            },
            {
                id: 'descriptionInput',
                name: 'description',
                type: 'text',
                label: 'Descripción',
                col: '3'
            }
        ],
        button: {
            id: 'addProductBtn',
            class: 'btn btn-primary w-100',
            content: 'Agregar'
        }
    }
} %>

<table id="table" class="display">
    <thead>
        <tr>
            <th>Folio</th>
            <th>Solicitud</th>
            <% if (user.department === 'Almacén') { %>
                <th>Área</th>
            <% } %>
            <th>Proyecto</th>
            <th>Aprobación</th>
            <th>Entrega</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody></tbody>
</table>

<%- include('../../../shared/modal', { form }) %>

<script>
    window.GOODS_ISSUE_CONTEXT = <%- JSON.stringify(user) %>;
</script>

<script type="module" src="/js/pages/warehouse/goodsIssuesPage.js"></script>

<%- contentFor('title') %>
Salidas del almacén
<%- contentFor('layoutType') %>
site