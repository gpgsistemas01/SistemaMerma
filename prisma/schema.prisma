generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Department {
  id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name  String @unique @db.VarChar(50)
  users User[]
  goodsReceipts GoodsReceipt[]
}

model Role {
  id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name  String @unique @db.VarChar(50)
  users User[]
}

model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  departmentId String     @db.Uuid
  roleId       String     @db.Uuid
  name         String     @unique @db.VarChar(50)
  password     String     @db.VarChar(50)
  isActive     Boolean    @default(true)
  profiles     Profile[]
  department   Department @relation(fields: [departmentId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])
}

model Profile {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String  @db.VarChar(50)
  lastName String  @db.VarChar(50)
  users User[]
  isActive Boolean @default(true)
  goodsReceipts GoodsReceipt[]
}

model Category {
  id       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String    @unique
  products Product[]
}

model Status {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique
  goodsReceipts GoodsReceipt[]
}

model Product {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @unique @db.VarChar(50)
  sku          String?   @db.VarChar(50)
  unitCost     Decimal  @db.Decimal(10, 2)
  currentStock Decimal  @db.Decimal(10, 2)
  expiryDate   DateTime?
  thickness    Decimal? @db.Decimal(10, 3)
  color        String?  @db.VarChar(50)
  type         String?  @db.VarChar(50)
  presentation String?  @db.VarChar(50)
  uomId        String   @db.Uuid
  categoryId   String   @db.Uuid
  isActive     Boolean  @default(true)
  maxStock     Decimal  @db.Decimal(10, 2)
  minStock     Decimal  @db.Decimal(10, 2)
  base         Decimal? @db.Decimal(10, 3)
  height       Decimal? @db.Decimal(10, 3)
  category     Category @relation(fields: [categoryId], references: [id])
  uom          UoM      @relation(fields: [uomId], references: [id])
  detailsGoodsReceipts DetailGoodsReceiptProduct[]
}

model UoM {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique @db.VarChar(10)
  abbrevation String    @unique @db.VarChar(10)
  product     Product[]
}

model Supplier {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String  @unique @db.VarChar(50)
  numberphone String? @db.VarChar(20)
  isActive    Boolean @default(true)
  goodsReceipts GoodsReceipt[]
}

model ReferenceNumberCounter {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prefix    String @unique @db.VarChar(10)
  counter   Int    @default(0)
}

model GoodsReceipt {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referenceNumber String     @unique @db.VarChar(50)
  supplierId   String     @db.Uuid
  receptionDate         DateTime
  observations String?    @db.VarChar(50)
  statusId     String     @db.Uuid
  departmentId String     @db.Uuid
  receivedById String     @db.Uuid
  department   Department @relation(fields: [departmentId], references: [id])
  receivedBy   Profile       @relation(fields: [receivedById], references: [id])
  supplier     Supplier   @relation(fields: [supplierId], references: [id])
  status       Status     @relation(fields: [statusId], references: [id])
  details        DetailGoodsReceiptProduct[]
}

model DetailGoodsReceiptProduct {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId       String  @db.Uuid
  goodsReceiptId String  @db.Uuid
  quantity        Decimal @db.Decimal(10, 2)
  description     String? @db.VarChar(50)
  goodsReceipt    GoodsReceipt   @relation(fields: [goodsReceiptId], references: [id])
  product         Product        @relation(fields: [productId], references: [id])
}