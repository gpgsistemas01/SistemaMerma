generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Department {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String                @unique @db.VarChar(50)
  users                User[]
  goodsReceipts        GoodsReceipt[]
  purchaseRequisitions PurchaseRequisition[]
  goodsIssues          GoodsIssue[]
  indicatorRelations  IndicatorDepartment[]
  notifications        Notification[]
}

model Role {
  id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name  String @unique @db.VarChar(50)
  users User[]
}

model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  departmentId String     @db.Uuid
  roleId       String     @db.Uuid
  name         String     @unique @db.VarChar(50)
  password     String     @db.VarChar(50)
  isActive     Boolean    @default(true)
  department   Department @relation(fields: [departmentId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])
  profiles     Profile[]  @relation("ProfileToUser")
  indicatorLogs indicator_logs[]
  Notification Notification[]
}

model Profile {
  id                            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                          String                @db.VarChar(50)
  lastName                      String                @db.VarChar(50)
  isActive                      Boolean               @default(true)
  goodsReceipts                 GoodsReceipt[]
  approvedGoodsReceipts         GoodsReceipt[]        @relation("ApproverGoodsReceiptRelation")
  users                         User[]                @relation("ProfileToUser")
  approverPurchaseRequisitions  PurchaseRequisition[] @relation("ApproverRelation")
  requesterPurchaseRequisitions PurchaseRequisition[] @relation("RequesterRelation")
  approverGoodsIssues           GoodsIssue[]          @relation("ApproverGoodsIssueRelation")
  requesterGoodsIssues          GoodsIssue[]          @relation("RequesterGoodsIssueRelation")
  warehouseStaffGoodsIssues     GoodsIssue[]          @relation("WarehouseStaffGoodsIssueRelation")
  deliveredPurchaseRequisitions PurchaseRequisition[] @relation("DeliveredByRelation")
  indicatorLogs                  indicator_logs[]
}

model Category {
  id       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String    @unique
  products Product[]
}

model Status {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String                @unique
  goodsReceipts        GoodsReceipt[]
  purchaseRequisitions PurchaseRequisition[]
  goodsIssues          GoodsIssue[]
}

model Product {
  id                          String                             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                        String                             @unique @db.VarChar(50)
  sku                         String?                            @db.VarChar(50)
  unitCost                    Decimal                            @db.Decimal(10, 2)
  currentStock                Decimal                            @db.Decimal(10, 2)
  expiryDate                  DateTime?
  thickness                   Decimal?                           @db.Decimal(10, 3)
  color                       String?                            @db.VarChar(50)
  type                        String?                            @db.VarChar(50)
  presentation                String?                            @db.VarChar(50)
  uomId                       String                             @db.Uuid
  categoryId                  String                             @db.Uuid
  isActive                    Boolean                            @default(true)
  maxStock                    Decimal                            @db.Decimal(10, 2)
  minStock                    Decimal                            @db.Decimal(10, 2)
  base                        Decimal?                           @db.Decimal(10, 3)
  height                      Decimal?                           @db.Decimal(10, 3)
  category                    Category                           @relation(fields: [categoryId], references: [id])
  uom                         UoM                                @relation(fields: [uomId], references: [id])
  detailsGoodsReceipts        DetailGoodsReceiptProduct[]
  detailsPurchaseRequisitions DetailPurchaseRequisitionProduct[]
  detailsGoodsIssues          DetailGoodsIssueProduct[]
  detailsMovement             DetailMovement[]
  supplierProducts            SupplierProduct[]
}

model UoM {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique @db.VarChar(10)
  abbrevation String    @unique @db.VarChar(10)
  product     Product[]
}

model Supplier {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String         @unique @db.VarChar(50)
  numberphone   String?        @db.VarChar(20)
  isActive      Boolean        @default(true)
  goodsReceipts GoodsReceipt[]
  products       SupplierProduct[]
}

model SupplierProduct {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  price     Decimal  @db.Decimal(10, 2)
  sku       String?  @db.VarChar(50)
  supplierId String   @db.Uuid
  productId  String   @db.Uuid
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])
}

model Notification {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String   @db.VarChar(100)
  message     String   @db.VarChar(255)
  type        String   @default("info") @db.VarChar(20)
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  entityId    String   @db.Uuid
  entityType  String   @db.VarChar(50)
  referenceNumber String?  @db.VarChar(50)
  userId      String?  @db.Uuid
  user        User?    @relation(fields: [userId], references: [id])
  departmentId      String?  @db.Uuid
  department        Department? @relation(fields: [departmentId], references: [id])
}

model Project {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referenceNumber      String                @unique @db.VarChar(50)
  client               String                @db.VarChar(50)
  name                 String                @db.VarChar(50)
  date                 DateTime
  purchaseRequisitions PurchaseRequisition[]
  goodsIssues          GoodsIssue[]
}

model ReferenceNumberCounter {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prefix  String @unique @db.VarChar(10)
  counter Int    @default(0)
}

model GoodsReceipt {
  id              String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referenceNumber String                      @unique @db.VarChar(50)
  supplierId      String                      @db.Uuid
  receptionDate   DateTime
  approveDate     DateTime?
  observations    String?                     @db.VarChar(50)
  statusId        String                      @db.Uuid
  departmentId    String                      @db.Uuid
  receivedById    String                      @db.Uuid
  approverId      String?                     @db.Uuid
  department      Department                  @relation(fields: [departmentId], references: [id])
  receivedBy      Profile                     @relation(fields: [receivedById], references: [id])
  approver        Profile?                    @relation("ApproverGoodsReceiptRelation", fields: [approverId], references: [id])
  supplier        Supplier                    @relation(fields: [supplierId], references: [id])
  status          Status                      @relation(fields: [statusId], references: [id])
  details         DetailGoodsReceiptProduct[]
  movements       InventoryMovement[]
}

model DetailGoodsReceiptProduct {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId        String         @db.Uuid
  goodsReceiptId   String         @db.Uuid
  quantity         Decimal        @db.Decimal(10, 2)
  goodsReceipt     GoodsReceipt   @relation(fields: [goodsReceiptId], references: [id])
  product          Product        @relation(fields: [productId], references: [id])
  detailMovementId String?         @unique @db.Uuid
  detailMovement   DetailMovement? @relation(fields: [detailMovementId], references: [id])
}

model PurchaseRequisition {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referenceNumber String    @unique @db.VarChar(50)
  approveDate     DateTime?
  requestDate     DateTime
  deliveryDate    DateTime?
  observations    String?   @db.VarChar(50)

  statusId      String  @db.Uuid
  departmentId  String  @db.Uuid
  approverId    String? @db.Uuid
  deliveredById String? @db.Uuid
  requesterId   String  @db.Uuid
  projectId     String  @db.Uuid

  department  Department @relation(fields: [departmentId], references: [id])
  approver    Profile?   @relation("ApproverRelation", fields: [approverId], references: [id])
  deliveredBy Profile?   @relation("DeliveredByRelation", fields: [deliveredById], references: [id])
  requester   Profile    @relation("RequesterRelation", fields: [requesterId], references: [id])
  status      Status     @relation(fields: [statusId], references: [id])
  project     Project    @relation(fields: [projectId], references: [id])

  details DetailPurchaseRequisitionProduct[]
}

model DetailPurchaseRequisitionProduct {
  id                    String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId             String  @db.Uuid
  purchaseRequisitionId String  @db.Uuid
  quantity              Decimal @db.Decimal(10, 2)

  purchaseRequisition PurchaseRequisition @relation(fields: [purchaseRequisitionId], references: [id])
  product             Product             @relation(fields: [productId], references: [id])
}

model GoodsIssue {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referenceNumber String    @unique @db.VarChar(50)
  approvedDate    DateTime?
  requestDate     DateTime
  deliveryDate    DateTime?
  observations    String?   @db.VarChar(50)

  statusId         String  @db.Uuid
  departmentId     String  @db.Uuid
  approverId       String? @db.Uuid
  requesterId      String  @db.Uuid
  warehouseStaffId String? @db.Uuid
  projectId        String  @db.Uuid

  department     Department @relation(fields: [departmentId], references: [id])
  approver       Profile?   @relation("ApproverGoodsIssueRelation", fields: [approverId], references: [id])
  requester      Profile    @relation("RequesterGoodsIssueRelation", fields: [requesterId], references: [id])
  warehouseStaff Profile?   @relation("WarehouseStaffGoodsIssueRelation", fields: [warehouseStaffId], references: [id])
  status         Status     @relation(fields: [statusId], references: [id])
  project        Project    @relation(fields: [projectId], references: [id])

  details  DetailGoodsIssueProduct[]
  movement InventoryMovement[]
}

model DetailGoodsIssueProduct {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId    String  @db.Uuid
  goodsIssueId String  @db.Uuid
  quantity     Decimal @db.Decimal(10, 2)

  goodsIssue       GoodsIssue     @relation(fields: [goodsIssueId], references: [id])
  product          Product        @relation(fields: [productId], references: [id])
  detailMovementId String?         @unique @db.Uuid
  detailMovement   DetailMovement? @relation(fields: [detailMovementId], references: [id])
}

model Reason {
  id String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique @db.VarChar(50)
  movements InventoryMovement[]
}

model InventoryMovement {
  id String @id  @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  goodsReceiptId String? @db.Uuid
  goodsIssueId   String? @db.Uuid
  reasonId       String  @db.Uuid

  goodsReceipt GoodsReceipt? @relation(fields: [goodsReceiptId], references: [id])
  goodsIssue   GoodsIssue?   @relation(fields: [goodsIssueId], references: [id])
  reason       Reason        @relation(fields: [reasonId], references: [id])

  date DateTime

  details DetailMovement[]
}

model DetailMovement {
  id String @id  @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  quantity Decimal @db.Decimal(10, 2)

  movementId String            @db.Uuid
  movement   InventoryMovement @relation(fields: [movementId], references: [id])

  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id])

  detailGoodsIssueProduct   DetailGoodsIssueProduct?
  detailGoodsReceiptProduct DetailGoodsReceiptProduct?
}

model Machine {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique @db.VarChar(50)
  dailyProductionCapacity Decimal? @db.Decimal(10, 2)
}

model indicator {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique @db.VarChar(50)
  unit String @db.VarChar(20)
  logs indicator_logs[]
  departmentRelations IndicatorDepartment[]
}

model indicator_logs {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  indicatorId String @db.Uuid
  profileId String? @db.Uuid
  userId String? @db.Uuid
  value Decimal @db.Decimal(10, 2)
  period DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  indicator indicator @relation(fields: [indicatorId], references: [id])
  profile Profile? @relation(fields: [profileId], references: [id])
  user User? @relation(fields: [userId], references: [id])

  @@unique([indicatorId, profileId, period])
}

model IndicatorDepartment {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  indicatorId String @db.Uuid
  departmentId String @db.Uuid

  indicator indicator @relation(fields: [indicatorId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  @@unique([indicatorId, departmentId])
}

model Shift {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique @db.VarChar(50)
  hours Decimal @db.Decimal(10, 2)
}

model Period {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  startDate DateTime
  endDate DateTime
  isActive Boolean @default(true)
}
